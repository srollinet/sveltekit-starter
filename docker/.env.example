# .env.example
# Copy this file to .env for local development:
#   cp .env.example .env
#
# All defaults below work immediately with `docker compose up`.

# ──────────────────────────────────────────────
# PostgreSQL (used by docker-compose.yml and src/lib/server/env.ts)
# ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Full connection URL consumed by the app and Drizzle ORM
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=sveltekit-starter

# Logging
LOG_LEVEL=info

# ──────────────────────────────────────────────
# Production Docker Compose Notes
# ──────────────────────────────────────────────
# When running via docker/docker-compose.prod.yml, DATABASE_URL must use
# the postgres service name instead of localhost:
#   DATABASE_URL=postgres://postgres:postgres@postgres:5432/app
#
# The ORIGIN variable is required for CSRF protection when not behind
# a reverse proxy that sets the Host header:
#   ORIGIN=https://yourdomain.com

# SvelteKit ORIGIN (required in production for CSRF validation)
# ORIGIN=http://localhost:3000
